      "source": [
        "import numpy as np\n",
        "from matplotlib import pyplot as plt\n",
        "ys = 200 + np.random.randn(100)\n",
        "x = [x for x in range(len(ys))]\n",
        "plt.plot(x, ys, '-')\n",
        "plt.fill_between(x, ys, 195, where=(ys > 195), facecolor='g', alpha=0.6)\n",
        "plt.title(\"Набойченко\")\n",
        "plt.show()\n"
      ]
    }
  ]
